# Public browser configuration. These values identify the Supabase project;
# privileged service-role keys must never use the VITE_ prefix.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Private server-only Cloudflare R2 configuration. Add these to Vercel without
# a VITE_ prefix; never expose them in the browser bundle.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pinpoint-user-cases

# Cloudflare Turnstile. The site key is safe for the browser; the secret is
# server-only and must never use the VITE_ prefix.
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
TURNSTILE_ALLOWED_HOSTNAMES=pinpoint-jade.vercel.app,localhost
